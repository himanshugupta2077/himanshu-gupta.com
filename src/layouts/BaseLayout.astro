---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Offensive Security Engineer. Builder of systems, tools, and ideas at the intersection of offensive security, automation, and AI.',
} = Astro.props;

const pathname = Astro.url.pathname;

const nav = [
  { href: '/research', label: 'research' },
  { href: '/projects', label: 'projects' },
  { href: '/playbooks', label: 'playbooks' },
  { href: '/about', label: 'about' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title === 'Himanshu Gupta' ? title : `${title} — Himanshu Gupta`}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-name">himanshu-gupta.com</a>
        <ul>
          {nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[{ active: pathname === href || pathname.startsWith(href + '/') }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Himanshu Gupta</p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1.1rem 2rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-name {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--green);
    font-weight: 600;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .site-name:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.75rem;
  }

  nav ul a {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    color: var(--text-muted);
    transition: color 0.1s;
  }

  nav ul a:hover,
  nav ul a.active {
    color: var(--text);
    text-decoration: none;
  }

  nav ul a.active {
    color: var(--green);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem;
    flex: 1;
    width: 100%;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.25rem 2rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    header { padding: 1rem; }
    nav { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    nav ul { gap: 1.25rem; }
    main { padding: 2rem 1rem; }
  }
</style>
