---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  collection: string;
}

const { title, description, date, tags, collection } = Astro.props;
const formattedDate = date.toISOString().slice(0, 10);
---

<BaseLayout title={title} description={description}>
  <article>
    <nav class="back-nav">
      <a href={`/${collection}`}>← {collection}</a>
    </nav>

    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map(tag => <span class="tag">#{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <hr />

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .back-nav {
    margin-bottom: 2.5rem;
  }

  .back-nav a {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    color: var(--text-muted);
  }

  .back-nav a:hover {
    color: var(--green);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: 1.875rem;
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  time {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.725rem;
    color: var(--green);
    background: rgba(63, 185, 80, 0.08);
    border: 1px solid rgba(63, 185, 80, 0.25);
    padding: 0.15em 0.5em;
    border-radius: 3px;
  }
</style>
